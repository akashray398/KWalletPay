<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".MainActivity">

    <!-- region TOP BAR (Profile, Settings, Notifications) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:background="@drawable/header_gradient_bg"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/profileCard"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="#33FFFFFF"
            app:strokeWidth="1.5dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/baseline_account_circle_24"
                android:contentDescription="Profile" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Swapped: Settings on right, Notification to its left -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/settingsCard"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/surface_card_border"
            app:strokeWidth="1dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_settings"
                app:tint="@color/text_primary"
                android:contentDescription="Settings" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/notificationCard"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/surface_card_border"
            app:strokeWidth="1dp"
            app:layout_constraintBottom_toBottomOf="@id/settingsCard"
            app:layout_constraintEnd_toStartOf="@id/settingsCard"
            app:layout_constraintTop_toTopOf="@id/settingsCard">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/outline_circle_notifications_24"
                app:tint="@color/text_primary"
                android:contentDescription="Notifications" />
            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/badge_dot" />
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <!-- endregion -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- region BRANDING -->
            <LinearLayout
                android:id="@+id/brandContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EXPERIENCE"
                    android:textSize="10sp"
                    android:letterSpacing="0.25"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/tvBrandName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-2dp"
                    android:layout_marginBottom="-2dp"
                    android:fontFamily="sans-serif-black"
                    android:text="KWalletPay"
                    android:textColor="#B3818CF8"
                    android:textSize="28sp"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="premium fintech"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:alpha="0.8"
                    android:letterSpacing="0.05"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>
            <!-- endregion -->

            <!-- region QUICK ACTIONS GRID -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardScanQR"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/bg_scan"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/pro_button_border"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toStartOf="@+id/cardCheckBalance"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/brandContainer">
                <include layout="@layout/item_action" android:id="@+id/includeScanQR"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCheckBalance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/bg_balance"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/pro_button_border"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toStartOf="@+id/cardShop"
                app:layout_constraintStart_toEndOf="@+id/cardScanQR"
                app:layout_constraintTop_toTopOf="@id/cardScanQR">
                <include layout="@layout/item_action" android:id="@+id/includeCheckBalance"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardShop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="20dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/bg_shop"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/pro_button_border"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/cardCheckBalance"
                app:layout_constraintTop_toTopOf="@id/cardScanQR">
                <include layout="@layout/item_action" android:id="@+id/includeShop"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDeposit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/bg_deposit"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/pro_button_border"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toStartOf="@+id/cardPaybill"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardScanQR">
                <include layout="@layout/item_action" android:id="@+id/includeDeposit"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPaybill"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/bg_paybill"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/pro_button_border"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toStartOf="@+id/cardTransfer"
                app:layout_constraintStart_toEndOf="@+id/cardDeposit"
                app:layout_constraintTop_toTopOf="@id/cardDeposit">
                <include layout="@layout/item_action" android:id="@+id/includePaybill"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTransfer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="20dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/bg_transfer"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/pro_button_border"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/cardPaybill"
                app:layout_constraintTop_toTopOf="@id/cardDeposit">
                <include layout="@layout/item_action" android:id="@+id/includeTransfer"/>
            </com.google.android.material.card.MaterialCardView>
            <!-- endregion -->

            <!-- region REFER CARD (Small & Compact) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/referCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/surface_card_border"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardDeposit">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/refer_card_bg"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="4dp">

                    <View
                        android:id="@+id/referGlow"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_blob_1"
                        android:alpha="0"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/referIcon"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="Refer &amp; Earn Rewards"
                            android:textColor="@color/white"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="Get ₹201 Cashback"
                            android:textColor="@color/colorAccent"
                            android:textSize="9sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/referButton"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="18dp"
                            android:layout_marginTop="2dp"
                            android:fontFamily="sans-serif-black"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="Invite Now"
                            android:textAllCaps="true"
                            android:textColor="@color/white"
                            android:textSize="7sp"
                            app:backgroundTint="@color/colorPrimary"
                            app:cornerRadius="9dp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/referIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:alpha="0.6"
                        android:rotation="-10"
                        android:src="@drawable/ic_gift_refer"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
            <!-- endregion -->

            <!-- region FINANCIAL SERVICES -->
            <TextView
                android:id="@+id/tvServicesTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-black"
                android:text="Financial Services"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/referCard" />

            <LinearLayout
                android:id="@+id/servicesGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:weightSum="4"
                app:layout_constraintTop_toBottomOf="@id/tvServicesTitle">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLoan"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/bg_loan"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp">
                    <include layout="@layout/item_action" android:id="@+id/includePersonalLoan"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGold"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="3dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/bg_gold"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp">
                    <include layout="@layout/item_action" android:id="@+id/includeGoldLoan"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCredit"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="3dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/bg_credit"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp">
                    <include layout="@layout/item_action" android:id="@+id/includeCreditScore"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRewards"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/bg_rewards"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp">
                    <include layout="@layout/item_action" android:id="@+id/includeRewards"/>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
            <!-- endregion -->

            <!-- region TRANSACTIONS SECTION -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/historyHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:paddingHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/servicesGrid">

                <TextView
                    android:id="@+id/historyLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Recent Transactions"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/btnSeeAllHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:fontFamily="sans-serif-medium"
                    android:padding="8dp"
                    android:text="See All"
                    android:textColor="@color/colorPrimary"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/transactionRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="20dp"
                app:layout_constraintTop_toBottomOf="@id/historyHeader"
                tools:listitem="@layout/item_transaction" />
            <!-- endregion -->

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- region BOTTOM NAVIGATION -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#CC111827"
        app:cardCornerRadius="36dp"
        app:cardElevation="12dp"
        app:strokeColor="@color/surface_card_border"
        app:strokeWidth="1.5dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:id="@+id/ivNavHome"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/baseline_home_24"
                    app:tint="@color/colorPrimary" />
                <TextView
                    android:id="@+id/tvNavHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="Home"
                    android:textColor="@color/colorPrimary"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navExplore"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:id="@+id/ivNavExplore"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/baseline_explore_24"
                    app:tint="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvNavExplore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Explore"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navHistory"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:id="@+id/ivNavHistory"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_history"
                    app:tint="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvNavHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="History"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <!-- endregion -->

</androidx.constraintlayout.widget.ConstraintLayout>
