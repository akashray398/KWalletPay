<?xml version="1.0" encoding="utf-8"?>
<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <Transition
        app:constraintSetEnd="@+id/end"
        app:constraintSetStart="@+id/start"
        app:duration="1000"
        app:motionInterpolator="easeInOut">
        <OnSwipe
            app:dragDirection="dragUp"
            app:touchAnchorId="@+id/referCard"
            app:touchAnchorSide="top" />

        <KeyFrameSet>
            <KeyPosition
                app:framePosition="50"
                app:keyPositionType="pathRelative"
                app:motionTarget="@+id/bgBlob1"
                app:percentX="0.2"
                app:percentY="0.1" />

            <KeyAttribute
                android:scaleX="1.3"
                android:scaleY="1.3"
                android:alpha="0.15"
                app:framePosition="50"
                app:motionTarget="@+id/bgBlob2" />
        </KeyFrameSet>
    </Transition>

    <ConstraintSet android:id="@+id/start">
    </ConstraintSet>

    <ConstraintSet android:id="@+id/end">
        <Constraint
            android:id="@+id/bgBlob1"
            android:layout_width="500dp"
            android:layout_height="500dp"
            android:alpha="0.12"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintHorizontal_bias="-0.8"
            app:layout_constraintVertical_bias="-0.4" />

        <Constraint
            android:id="@+id/bgBlob2"
            android:layout_width="450dp"
            android:layout_height="450dp"
            android:alpha="0.12"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_bias="1.8"
            app:layout_constraintVertical_bias="1.6" />

        <Constraint
            android:id="@+id/appTitleContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="@+id/profileCard"
            app:layout_constraintTop_toBottomOf="@+id/profileCard">
            <Transform
                android:scaleX="0.65"
                android:scaleY="0.65"
                android:translationX="-35dp"
                android:translationY="-20dp" />
            <PropertySet android:alpha="0.6" />
        </Constraint>

        <Constraint
            android:id="@+id/cardScanQR"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="6dp"
            app:layout_constraintEnd_toStartOf="@+id/cardCheckBalance"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/appTitleContainer">
            <Transform android:translationY="-30dp" />
        </Constraint>

        <Constraint
            android:id="@+id/referCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardDeposit">
            <Transform android:translationY="-40dp" />
        </Constraint>
    </ConstraintSet>
</MotionScene>
