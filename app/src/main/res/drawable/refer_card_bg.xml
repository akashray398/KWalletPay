<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Layer: Solid Deep Slate -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0F172A" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- Main Gradient Layer (Frosted Indigo) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#306366F1"
                android:centerColor="#208B5CF6"
                android:endColor="#10D946EF"
                android:type="linear" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- Top Left Accent Glow -->
    <item android:top="-50dp" android:left="-50dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="180dp"
                android:startColor="#25818CF8"
                android:endColor="#00000000" />
            <size android:width="200dp" android:height="200dp" />
        </shape>
    </item>

    <!-- Bottom Right Accent Glow -->
    <item android:bottom="-80dp" android:right="-80dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="200dp"
                android:startColor="#15F472B6"
                android:endColor="#00000000" />
            <size android:width="250dp" android:height="250dp" />
        </shape>
    </item>

    <!-- Glassmorphism Inner Stroke -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1.2dp" android:color="#20FFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</layer-list>