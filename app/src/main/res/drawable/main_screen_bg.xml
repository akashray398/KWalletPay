<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/background_gray" />
        </shape>
    </item>

    <!-- Top Soft Gradient -->
    <item android:bottom="500dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:endColor="#104F46E5"
                android:startColor="#107C3AED"
                android:type="linear" />
        </shape>
    </item>

    <!-- Decorative Top Circle Left -->
    <item
        android:width="300dp"
        android:height="300dp"
        android:left="-100dp"
        android:top="-150dp">
        <shape android:shape="oval">
            <solid android:color="#084F46E5" />
        </shape>
    </item>

    <!-- Decorative Top Circle Right -->
    <item
        android:width="200dp"
        android:height="200dp"
        android:right="-50dp"
        android:top="-50dp">
        <shape android:shape="oval">
            <solid android:color="#087C3AED" />
        </shape>
    </item>
</layer-list>