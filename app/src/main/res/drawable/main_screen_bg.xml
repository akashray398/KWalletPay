<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Solid base color -->
    <item>
        <shape>
            <solid android:color="#EEF2FF" />
        </shape>
    </item>
    
    <!-- Top Left Mesh -->
    <item android:top="-150dp" android:left="-150dp">
        <shape android:shape="oval">
            <size android:width="500dp" android:height="500dp" />
            <gradient
                android:startColor="#206366F1"
                android:endColor="#006366F1"
                android:type="radial"
                android:gradientRadius="350dp" />
        </shape>
    </item>

    <!-- Bottom Right Mesh -->
    <item android:bottom="-200dp" android:right="-200dp">
        <shape android:shape="oval">
            <size android:width="600dp" android:height="600dp" />
            <gradient
                android:startColor="#208B5CF6"
                android:endColor="#008B5CF6"
                android:type="radial"
                android:gradientRadius="400dp" />
        </shape>
    </item>

    <!-- Mid Left Mesh -->
    <item android:top="300dp" android:left="-100dp">
        <shape android:shape="oval">
            <size android:width="400dp" android:height="400dp" />
            <gradient
                android:startColor="#1506B6D4"
                android:endColor="#0006B6D4"
                android:type="radial"
                android:gradientRadius="300dp" />
        </shape>
    </item>
</layer-list>